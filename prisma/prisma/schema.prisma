generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  subscriptions  Subscription[]
  createdAt      DateTime       @default(now())
}

model Subscription {
  id           String   @id @default(cuid())
  name         String
  price        Float
  renewalDate  DateTime

  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
